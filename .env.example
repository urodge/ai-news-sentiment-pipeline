# Copy this file to .env and fill in your values
# cp .env.example .env

# Get a free key at https://newsapi.org (takes 2 minutes)
NEWS_API_KEY=your_newsapi_key_here

# Optional: Slack webhook for pipeline alerts
# Create at: Slack → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Optional: GCP project for BigQuery
GCP_PROJECT_ID=
GCP_DATASET=news_pipeline
